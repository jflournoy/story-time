{
  "name": "story-time",
  "version": "0.1.0",
  "description": "AI-assisted narrative development using local LLMs - A flexible web-based tool for writers",
  "scripts": {
    "// Story Time": "=== Story Time application commands ===",
    "frontend:dev": "vite frontend",
    "frontend:build": "vite build frontend",
    "dev": "tsx watch backend/src/index.ts",
    "build": "tsc -p backend/tsconfig.json",
    "start": "node backend/dist/index.js",
    "backend:dev": "tsx watch backend/src/index.ts",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:test": "vitest run backend/tests",
    "backend:test:watch": "vitest watch backend/tests",
    "// LLM Service": "=== Python LLM service commands ===",
    "llm:install": "cd services && uv sync",
    "llm:start": "cd services && uv run uvicorn llm_service:app --port 8011",
    "llm:dev": "cd services && uv run uvicorn llm_service:app --reload --port 8011",
    "llm:health": "curl -s http://localhost:8011/health | cat",
    "// Development Modes": "=== Development mode commands ===",
    "service:llm": "npm run llm:start",
    "service:backend": "LLM_PROVIDER=local LLM_SERVICE_URL=http://localhost:8011 PORT=4001 npm run backend:dev",
    "service:all": "concurrently -n llm,api -c blue,green \"npm run service:llm\" \"npm run service:backend\"",
    "dev:local": "npm run service:all",
    "dev:ollama": "npm run backend:dev",
    "validate": "echo 'Validating command templates...' && find .claude/commands -name '*.md' -exec echo 'Checking {}' \\; -exec head -5 {} \\;",
    "list-commands": "ls -1 .claude/commands/*.md | sed 's|.claude/commands/||' | sed 's|\\.md$||' | sort",
    "// Core Workflow": "=== Core workflow commands ===",
    "hygiene": "npm run hygiene:quick --silent",
    "hygiene:quick": "npm run lint:check && npm run test:check && npm run markdown:lint && npm run git:status:summary",
    "hygiene:full": "npm run lint:check && npm run test:check && npm run deps:check && npm run git:status:full && npm run maintain:summary",
    "todo:list": "node scripts/todo-github.js list",
    "todo:add": "node scripts/todo-github.js add",
    "todo:done": "node scripts/todo-github.js done",
    "todo:comment": "node scripts/todo-github.js comment",
    "todo:stats": "node scripts/todo-github.js stats",
    "commit": "npm run commit:check",
    "commit:check": "npm run lint:check --silent && npm run test:check --silent && npm run markdown:lint --silent && npm run feature:check --silent",
    "// Quality Checks": "=== Quality and testing ===",
    "lint:check": "if [ -f 'eslint.config.js' ] || [ -f '.eslintrc.js' ]; then npx eslint . --max-warnings 10 2>/dev/null || echo '❌ Lint issues found'; else echo '⚠️ No linter configured'; fi",
    "test:check": "if grep -q '\"test\"' package.json 2>/dev/null; then npm test 2>/dev/null || echo '❌ Tests failing'; else echo '⚠️ No tests configured'; fi",
    "feature:check": "node scripts/feature-check.js",
    "quality:all": "npm run lint:check && npm run test:check && npm run feature:check",
    "quality:pre-commit": "npm run lint:check --silent && npm run test:check --silent && npm run feature:check --silent && npm run git:check:staged",
    "// Git Operations": "=== Git status and operations ===",
    "git:status:summary": "echo \"Branch: $(git branch --show-current 2>/dev/null || echo 'unknown') | Changes: $(git status --porcelain | wc -l | xargs) files\"",
    "git:status:full": "git status --short",
    "git:check:staged": "test -n \"$(git diff --cached --name-only)\" && echo '✅ Files staged' || (echo '❌ No staged files' && exit 1)",
    "git:uncommitted": "git diff --stat",
    "git:unpushed": "git log --oneline @{u}..HEAD 2>/dev/null | wc -l | xargs",
    "// Dependencies": "=== Dependency management ===",
    "deps:check": "npm outdated --depth=0 2>/dev/null || echo '✅ All dependencies up to date'",
    "deps:audit": "npm audit --audit-level=high 2>/dev/null || echo '✅ No high severity vulnerabilities'",
    "deps:count": "node -e \"const p=require('./package.json');console.log('Prod: '+(Object.keys(p.dependencies||{}).length)+' | Dev: '+(Object.keys(p.devDependencies||{}).length))\"",
    "// Maintainability": "=== Code maintainability analysis ===",
    "maintain:files": "find . -name '*.js' 2>/dev/null | grep -v node_modules | wc -l | xargs",
    "maintain:largest": "find . -name '*.js' 2>/dev/null | grep -v node_modules | xargs wc -l 2>/dev/null | sort -rn | head -5",
    "maintain:debt": "echo \"TODO: $(grep -r 'TODO' --exclude-dir=node_modules . 2>/dev/null | wc -l) | FIXME: $(grep -r 'FIXME' --exclude-dir=node_modules . 2>/dev/null | wc -l)\"",
    "maintain:summary": "echo \"Files: $(npm run maintain:files --silent) | Debt markers: $(grep -r 'TODO\\|FIXME' --exclude-dir=node_modules . 2>/dev/null | wc -l)\"",
    "// Session Management": "=== Session analysis and retrospectives ===",
    "retrospective": "node scripts/retrospective.js",
    "session:save": "node scripts/session-history.js save",
    "session:delta": "node scripts/session-history.js delta",
    "session:list": "node scripts/session-history.js list",
    "session:archive": "node scripts/session-history.js archive",
    "// Documentation": "=== Documentation management ===",
    "docs": "node scripts/docs.js",
    "docs:examples": "node scripts/docs.js examples",
    "markdown:lint": "remark . --quiet",
    "markdown:fix": "remark . --output",
    "// Advanced Commands": "=== Advanced workflow commands ===",
    "learn": "node scripts/learn.js",
    "tdd": "node scripts/tdd.js",
    "reflect:quick": "node scripts/reflect.js quick",
    "reflect:decision": "node scripts/reflect.js decision",
    "reflect:pattern": "node scripts/reflect.js pattern",
    "reflect:assumption": "node scripts/reflect.js assumption",
    "// Monitoring": "=== GitHub monitoring commands ===",
    "monitor:start": "node scripts/monitor-repo.js &",
    "monitor:status": "node scripts/monitor-repo.js status",
    "monitor:stop": "pkill -f 'node scripts/monitor-repo.js' || echo 'Monitor not running'",
    "monitor:diff": "node scripts/monitor-repo.js diff",
    "monitor:reset": "node scripts/monitor-repo.js reset",
    "monitor:failures": "node scripts/monitor-repo.js failures",
    "monitor:history": "node scripts/monitor-repo.js history",
    "monitor:clear": "node scripts/monitor-repo.js clear",
    "monitor:config": "node scripts/monitor-repo.js config",
    "// Testing": "=== Testing commands ===",
    "test": "SKIP_SESSION_SAVE=1 node --test test/*.test.js",
    "test:verbose": "node --test --test-reporter=spec test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "// CI/CD": "=== Continuous Integration commands ===",
    "quality:ci": "npm run lint:check && npm test && npm run docs validate",
    "ci:pre-push": "npm run quality:ci && npm run git:unpushed",
    "ci:validate-docs": "node -e \"const d=require('./scripts/docs.js');process.exit(d.validateCommitExists('HEAD')?0:1)\"",
    "// Utilities": "=== Utility commands ===",
    "files:find": "find . -name",
    "search:code": "grep -r --exclude-dir=node_modules",
    "clean:artifacts": "rm -rf dist build *.log",
    "stats:project": "echo \"JS Files: $(npm run maintain:files --silent) | Commits: $(git rev-list --count HEAD 2>/dev/null || echo '0') | Branch: $(git branch --show-current)\"",
    "prepare": "husky"
  },
  "keywords": [
    "writing",
    "narrative",
    "llm",
    "ollama",
    "creative-writing",
    "ai-writing",
    "text-processing",
    "story-development"
  ],
  "author": "John Flournoy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jflournoy/story-time.git"
  },
  "bugs": {
    "url": "https://github.com/jflournoy/story-time/issues"
  },
  "homepage": "https://github.com/jflournoy/story-time#readme",
  "files": [
    ".claude/",
    "docs/",
    "scripts/",
    "CLAUDE.md",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "story-time": "./backend/dist/index.js"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ollama": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.33.0",
    "husky": "^9.1.7",
    "remark": "^15.0.1",
    "remark-cli": "^12.0.1",
    "remark-lint-code-block-style": "^4.0.1",
    "remark-lint-emphasis-marker": "^4.0.1",
    "remark-lint-fenced-code-flag": "^4.2.0",
    "remark-lint-heading-style": "^4.0.1",
    "remark-lint-list-item-indent": "^4.0.1",
    "remark-lint-maximum-line-length": "^4.1.1",
    "remark-lint-no-dead-urls": "^2.0.1",
    "remark-lint-no-duplicate-headings": "^4.0.1",
    "remark-lint-no-empty-url": "^4.0.1",
    "remark-lint-no-reference-like-url": "^4.0.1",
    "remark-lint-no-undefined-references": "^5.0.2",
    "remark-lint-no-unused-definitions": "^4.0.2",
    "remark-lint-ordered-list-marker-style": "^4.0.1",
    "remark-lint-strong-marker": "^4.0.1",
    "remark-lint-table-cell-padding": "^5.1.1",
    "remark-lint-table-pipes": "^5.0.1",
    "remark-lint-unordered-list-marker-style": "^4.0.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-validate-links": "^13.1.0",
    "supertest": "^7.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^1.0.4"
  }
}
