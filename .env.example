# Story Time Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Alternative models you can use:
# OLLAMA_MODEL=llama3:70b          # Better quality, slower
# OLLAMA_MODEL=mistral:7b          # Fast, good quality
# OLLAMA_MODEL=qwen2.5:14b         # Excellent for creative writing
# OLLAMA_MODEL=mixtral:8x7b        # High quality, resource intensive

# Frontend Configuration (for future use)
# FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
