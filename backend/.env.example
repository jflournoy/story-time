# LLM Provider Configuration
LLM_PROVIDER=local

# Local LLM Service Configuration (llama.cpp via Python service)
LLM_SERVICE_URL=http://localhost:8003

# Python LLM Service Configuration (for services/llm_service.py)
LLM_MODEL_REPO=TheBloke/Mistral-7B-Instruct-v0.2-GGUF
LLM_MODEL_FILE=mistral-7b-instruct-v0.2.Q4_K_M.gguf
LLM_GPU_LAYERS=0
LLM_CONTEXT_LENGTH=4096
LLM_SERVICE_HOST=0.0.0.0
LLM_SERVICE_PORT=8003
LLM_PRELOAD_MODEL=false

# Backend Configuration
PORT=3000
NODE_ENV=development
